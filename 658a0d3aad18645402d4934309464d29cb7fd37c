      "message": "package com.rootguard.app;\n\nimport android.app.DownloadManager;\nimport android.content.BroadcastReceiver;\nimport android.content.Context;\nimport android.content.Intent;\nimport android.content.IntentFilter;\nimport android.database.Cursor;\nimport android.net.Uri;\nimport android.os.Bundle;\nimport android.os.Environment;\nimport android.widget.Button;\nimport android.widget.TextView;\nimport android.widget.Toast;\nimport androidx.appcompat.app.AppCompatActivity;\nimport java.io.BufferedReader;\nimport java.io.DataOutputStream;\nimport java.io.InputStreamReader;\n\npublic class MainActivity extends AppCompatActivity {\n\n    Button btnBloquear, btnRestaurar, btnDescargar;\n    TextView txtEstado, txtConsola, txtInfoRom;\n    \n    // URL de LineageOS para Motorola (ejemplo - verificar modelo exacto)\n    private static final String ROM_URL \u003d \"https://download.lineageos.org/api/v2/devices/panther/builds\";\n    private long downloadId \u003d -1;\n\n    @Override\n    protected void onCreate(Bundle savedInstanceState) {\n        super.onCreate(savedInstanceState);\n        setContentView(R.layout.activity_main);\n\n        btnBloquear \u003d findViewById(R.id.btnBloquear);\n        btnRestaurar \u003d findViewById(R.id.btnRestaurar);\n        btnDescargar \u003d findViewById(R.id.btnDescargar);\n        txtEstado \u003d findViewById(R.id.txtEstado);\n        txtConsola \u003d findViewById(R.id.txtConsola);\n        txtInfoRom \u003d findViewById(R.id.txtInfoRom);\n\n        // \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d BOTÓN 1: BLOQUEAR ROOT \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\n        btnBloquear.setOnClickListener(v -\u003e {\n            logConsola(\"\u003e 🔒 BLOQUEANDO SISTEMA...\");\n            \n            String ordenes \u003d \n                \"echo \u0027\u003d\u003d\u003d ROOT GUARD - MODO BLOQUEO \u003d\u003d\u003d\u0027 \u0026\u0026 \" +\n                \"mount -o remount,ro /system 2\u003e/dev/null; \" +\n                \"mount -o remount,ro /vendor 2\u003e/dev/null; \" +\n                \"mv /system/bin/su /system/bin/.su_guard 2\u003e/dev/null; \" +\n                \"mv /system/xbin/su /system/xbin/.su_guard 2\u003e/dev/null; \" +\n                \"setprop sys.usb.config mtp 2\u003e/dev/null; \" +\n                \"stop adbd 2\u003e/dev/null; \" +\n                \"echo \u0027BLOQUEADO\u0027 \u003e /data/local/tmp/rootguard.status; \" +\n                \"echo \u0027✅ SISTEMA CONGELADO\u0027\";\n            \n            String resultado \u003d ejecutarRoot(ordenes);\n            logConsola(resultado);\n            \n            txtEstado.setText(\"[ Estado: 🔒 PROTEGIDO ]\");\n            txtEstado.setTextColor(0xFF00FF41);\n            Toast.makeText(this, \"Root bloqueado. Nadie modifica.\", Toast.LENGTH_LONG).show();\n        });\n\n        // \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d BOTÓN 2: RESTAURAR STOCK \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\n        btnRestaurar.setOnClickListener(v -\u003e {\n            logConsola(\"\u003e ↩️ RESTAURANDO ANDROID ORIGINAL...\");\n            \n            String ordenes \u003d \n                \"echo \u0027\u003d\u003d\u003d ROOT GUARD - RESTAURACIÓN \u003d\u003d\u003d\u0027 \u0026\u0026 \" +\n                \"magisk --remove-modules 2\u003e/dev/null; \" +\n                \"mv /system/bin/.su_guard /system/bin/su 2\u003e/dev/null; \" +\n                \"mv /system/xbin/.su_guard /system/xbin/su 2\u003e/dev/null; \" +\n                \"rm -rf /data/adb/modules/* 2\u003e/dev/null; \" +\n                \"echo \u0027STOCK\u0027 \u003e /data/local/tmp/rootguard.status; \" +\n                \"echo \u0027✅ LISTO - Reiniciando...\u0027 \u0026\u0026 \" +\n                \"sleep 3 \u0026\u0026 reboot\";\n            \n            String resultado \u003d ejecutarRoot(ordenes);\n            logConsola(resultado);\n            \n            txtEstado.setText(\"[ Estado: ↩️ RESTAURANDO... ]\");\n            txtEstado.setTextColor(0xFFFFFF00);\n            Toast.makeText(this, \"Borrando root... Reiniciando limpio.\", Toast.LENGTH_LONG).show();\n        });\n\n        // \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d BOTÓN 3: DESCARGAR ROM LIMPIA \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\n        btnDescargar.setOnClickListener(v -\u003e {\n            logConsola(\"\u003e 📥 INICIANDO DESCARGA LINEAGEOS...\");\n            descargarRom();\n        });\n\n        // Registrar receptor para saber cuando termina la descarga\n        registerReceiver(onDownloadComplete, new IntentFilter(DownloadManager.ACTION_DOWNLOAD_COMPLETE));\n    }\n\n    // \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d DESCARGAR ROM \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\n    private void descargarRom() {\n        // URL directa de LineageOS (necesitas verificar el codename exacto de tu Moto G14)\n        // Codename común para Moto G14: \"penang\" o \"fogos\" - VERIFICAR EN XDA\n        String urlRom \u003d \"https://mirror.lineageos.org/full/penang/20240615/lineage-21.0-20240615-nightly-penang-signed.zip\";\n        \n        DownloadManager.Request request \u003d new DownloadManager.Request(Uri.parse(urlRom));\n        \n        // Configuración de descarga\n        request.setTitle(\"LineageOS para Moto G14\");\n        request.setDescription(\"Descargando ROM limpia...\");\n        request.setNotificationVisibility(DownloadManager.Request.VISIBILITY_VISIBLE_NOTIFY_COMPLETED);\n        request.setDestinationInExternalPublicDir(Environment.DIRECTORY_DOWNLOADS, \"lineageos-moto-g14.zip\");\n        request.setAllowedOverMetered(true);\n        request.setAllowedOverRoaming(true);\n        \n        DownloadManager dm \u003d (DownloadManager) getSystemService(Context.DOWNLOAD_SERVICE);\n        downloadId \u003d dm.enqueue(request);\n        \n        logConsola(\"\u003e ⏳ Descargando... ~800MB\");\n        txtInfoRom.setText(\"ROM: DESCARGANDO...\\nTamaño: ~800MB\\nGuardado en: /Download/lineageos-moto-g14.zip\");\n        \n        Toast.makeText(this, \"Descarga iniciada. Revisa notificaciones.\", Toast.LENGTH_LONG).show();\n    }\n\n    // \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d RECEPTOR: DESCARGA TERMINADA \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\n    private BroadcastReceiver onDownloadComplete \u003d new BroadcastReceiver() {\n        @Override\n        public void onReceive(Context context, Intent intent) {\n            long id \u003d intent.getLongExtra(DownloadManager.EXTRA_DOWNLOAD_ID, -1);\n            if (id \u003d\u003d downloadId) {\n                DownloadManager dm \u003d (DownloadManager) getSystemService(Context.DOWNLOAD_SERVICE);\n                Cursor cursor \u003d dm.query(new DownloadManager.Query().setFilterById(id));\n                \n                if (cursor.moveToFirst()) {\n                    int status \u003d cursor.getInt(cursor.getColumnIndex(DownloadManager.COLUMN_STATUS));\n                    \n                    if (status \u003d\u003d DownloadManager.STATUS_SUCCESSFUL) {\n                        String uri \u003d cursor.getString(cursor.getColumnIndex(DownloadManager.COLUMN_LOCAL_URI));\n                        logConsola(\"\u003e ✅ DESCARGA COMPLETA: \" + uri);\n                        txtInfoRom.setText(\"ROM: ✅ DESCARGADA\\nArchivo: lineageos-moto-g14.zip\\nListo para flashear con TWRP\");\n                        Toast.makeText(context, \"ROM descargada. Instala con TWRP recovery.\", Toast.LENGTH_LONG).show();\n                    } else {\n                        int reason \u003d cursor.getInt(cursor.getColumnIndex(DownloadManager.COLUMN_REASON));\n                        logConsola(\"\u003e ❌ ERROR DESCARGA: \" + reason);\n                        txtInfoRom.setText(\"ROM: ❌ ERROR\\nIntenta descargar manualmente desde lineageos.org\");\n                    }\n                }\n                cursor.close();\n            }\n        }\n    };\n\n    // \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d EJECUTAR COMANDOS ROOT \u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\u003d\n    private String ejecutarRoot(String comandos) {\n        StringBuilder salida \u003d new StringBuilder();\n        try {\n            Process root \u003d Runtime.getRuntime().exec(\"su\");\n            DataOutputStream canal \u003d new DataOutputStream(root.getOutputStream());\n            BufferedReader lector \u003d new BufferedReader(new InputStreamReader(root.getInputStream()));\n            \n            canal.writeBytes(comandos + \"\\n\");\n            canal.writeBytes(\"exit\\n\");\n            canal.flush();\n            canal.close();\n            \n            String linea;\n            while ((linea \u003d lector.readLine()) !\u003d null) {\n                salida.append(linea).append(\"\\n\");\n            }\n            root.waitFor();\n            return salida.toString();\n            \n        } catch (Exception e) {\n            return \"ERROR: Sin root - \" + e.getMessage();\n        }\n    }\n\n    private void logConsola(String texto) {\n        txtConsola.setText(texto);\n    }\n\n    @Override\n    protected void onDestroy() {\n        super.onDestroy();\n        unregisterReceiver(onDownloadComplete);\n    }\n}",
